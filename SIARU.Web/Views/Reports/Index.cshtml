@{
    ViewData["Title"] = "Informes";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Informes</h1>
        <p class="page-subtitle">
            Selecciona el tipo de informe académico que deseas consultar.
        </p>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-md-6">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <h3 class="dashboard-card-title">Informe por asignatura</h3>
                <p class="dashboard-card-text">
                    Consulta los datos completos de una asignatura, sus titulaciones, profesores,
                    incompatibilidades y equivalencias.
                </p>
                <a class="btn app-secondary-button disabled" href="#">Próximamente</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <h3 class="dashboard-card-title">Informe por profesor</h3>
                <p class="dashboard-card-text">
                    Consulta el área, departamento, despacho, horarios y asignaturas impartidas.
                </p>
                <a class="btn app-secondary-button disabled" href="#">Próximamente</a>
            </div>
        </div>
    </div>
</div>