@{
    ViewData["Title"] = "Informes";
}

<div class="page-header">
    <h1 class="page-title">Informes académicos</h1>
    <p class="page-subtitle">Consulta reportes por asignatura o por profesor.</p>
</div>

<div class="row g-4">
    <div class="col-12 col-md-6">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <h3 class="dashboard-card-title">Informe por asignatura</h3>
                <p class="dashboard-card-text">
                    Busca una asignatura y consulta sus titulaciones asociadas y profesores que la imparten.
                </p>
                <a class="btn app-secondary-button" asp-action="Subject">Buscar asignatura</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="dashboard-card">
            <div class="dashboard-card-body">
                <h3 class="dashboard-card-title">Informe por profesor</h3>
                <p class="dashboard-card-text">
                    Busca un profesor y consulta sus horarios y asignaturas impartidas.
                </p>
                <a class="btn app-secondary-button" asp-action="Professor">Buscar profesor</a>
            </div>
        </div>
    </div>
</div>