@model IEnumerable<SIARU.Application.DTOs.Reports.SubjectReportSearchResultDto>

@{
    ViewData["Title"] = "Buscar asignatura";
    var term = ViewBag.SearchTerm as string;
}

<div class="page-header">
    <h1 class="page-title">Informe por asignatura</h1>
    <p class="page-subtitle">Busca una asignatura por código o nombre.</p>
</div>

<div class="form-card mb-4">
    <form method="get">
        <div class="row g-3 align-items-end">
            <div class="col-md-10">
                <label class="form-label">Buscar</label>
                <input type="text" name="term" value="@term" class="form-control app-form-control" placeholder="Ejemplo: SI101 o Programación" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn app-primary-button w-100">Buscar</button>
            </div>
        </div>
    </form>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table app-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Área</th>
                    <th class="text-end">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">No se encontraron asignaturas.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Code</td>
                            <td>@item.Name</td>
                            <td>@item.KnowledgeAreaName</td>
                            <td class="text-end">
                                <a asp-action="SubjectDetails" asp-route-code="@item.Code" class="btn btn-sm app-table-button">Ver informe</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>