@using SIARU.Application.Common
@{
    ViewData["Title"] = "Inicio";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<section class="landing-hero">
    <div class="landing-hero-inner">
        <div class="landing-hero-copy">
            <div class="landing-kicker">Plataforma académica</div>

            <h1 class="landing-title">
                Gestiona la
                <span>información académica</span>
            </h1>

            <p class="landing-description">
                SIARU centraliza asignaturas, profesores, titulaciones y reportes universitarios
                en una sola plataforma clara, moderna y escalable.
            </p>

            <div class="landing-actions">
                @if (!isAuthenticated)
                {
                    <a class="btn app-primary-button" href="#">Iniciar sesión</a>
                }
                else
                {
                    <a class="btn app-primary-button" asp-controller="Reports" asp-action="Index">Ir a informes</a>
                }

                <a class="btn app-outline-button" asp-controller="Home" asp-action="Index">Explorar plataforma</a>
            </div>
        </div>

        <div class="landing-hero-panel">
            <div class="hero-panel-card hero-panel-card-soft">
                <span class="hero-panel-label">Módulo</span>
                <h3>Estructura académica</h3>
                <p>Departamentos, áreas de conocimiento y titulaciones organizadas de forma centralizada.</p>
            </div>

            <div class="hero-panel-card hero-panel-card-accent">
                <span class="hero-panel-label">Informes</span>
                <h3>Reportes de asignaturas y profesores</h3>
                <p>Consulta la información académica en vistas listas para imprimir o exportar a PDF.</p>
            </div>
        </div>
    </div>
</section>

<section class="landing-grid-section">
    <div class="section-heading">
        <span class="section-kicker">Acceso rápido</span>
        <h2 class="section-title">Explora los módulos principales</h2>
        <p class="section-text">
            Una vista inicial más clara para navegar rápidamente por las funciones principales del sistema.
        </p>
    </div>

    <div class="landing-grid">
        <article class="landing-card landing-card-large">
            <div class="landing-card-body">
                <span class="landing-card-label">Estructura</span>
                <h3>Gestión académica base</h3>
                <p>
                    Organiza departamentos, áreas de conocimiento y titulaciones que sirven como
                    base del sistema.
                </p>
                <span class="landing-card-link">Departamentos · Áreas · Titulaciones</span>
            </div>
        </article>

        <article class="landing-card landing-card-image">
            <div class="landing-card-body">
                <span class="landing-card-label">Asignaturas</span>
                <h3>Catálogo académico</h3>
                <p>Consulta y administra la oferta académica, créditos, incompatibilidades y equivalencias.</p>
            </div>
        </article>

        <article class="landing-card landing-card-accent">
            <div class="landing-card-body">
                <span class="landing-card-label">Informes</span>
                <h3>Información lista para consulta</h3>
                <p>Reportes detallados por asignatura y profesor, optimizados para lectura e impresión.</p>
            </div>
        </article>

        <article class="landing-card landing-card-image-alt">
            <div class="landing-card-body">
                <span class="landing-card-label">Profesores</span>
                <h3>Docencia y horarios</h3>
                <p>Visualiza despacho, área, impartición y horarios de consulta por profesor.</p>
            </div>
        </article>
    </div>
</section>

<section class="landing-info-section">
    <div class="landing-info-copy">
        <span class="section-kicker">Sobre SIARU</span>
        <h2 class="section-title section-title-narrow">
            Una plataforma para estructurar y consultar la vida académica universitaria.
        </h2>
        <p class="section-text">
            SIARU sustituye la gestión basada en ficheros por una base de datos relacional,
            mejorando consistencia, trazabilidad y generación de informes académicos.
        </p>

        <ul class="landing-feature-list">
            <li>Centralización de información académica</li>
            <li>Mejor integridad y consistencia de datos</li>
            <li>Consultas rápidas y estructura más clara</li>
            <li>Base lista para futuras ampliaciones del sistema</li>
        </ul>
    </div>

    <div class="landing-info-side">
        <div class="info-side-card">
            <span class="landing-card-label">Estado actual</span>
            <h3>Base sólida para futuras fases</h3>
            <p>
                La plataforma ya prepara la estructura para módulos de asignaturas,
                profesores, horarios, imparticiones e informes.
            </p>
        </div>
    </div>
</section>

@if (isAuthenticated)
{
    <section class="landing-auth-section">
        <div class="section-heading">
            <span class="section-kicker">Sesión activa</span>
            <h2 class="section-title">Accesos disponibles</h2>
            <p class="section-text">
                Sesión iniciada como <strong>@(User.Identity?.Name ?? "Usuario")</strong>.
            </p>
        </div>

        <div class="dashboard-cards-grid">
            <div class="dashboard-card">
                <div class="dashboard-card-body">
                    <h3 class="dashboard-card-title">Informes</h3>
                    <p class="dashboard-card-text">Consulta los reportes del sistema.</p>
                    <a class="btn app-secondary-button" asp-controller="Reports" asp-action="Index">Ver informes</a>
                </div>
            </div>

            @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.StudentServicesStaff))
            {
                <div class="dashboard-card">
                    <div class="dashboard-card-body">
                        <h3 class="dashboard-card-title">Departamentos</h3>
                        <p class="dashboard-card-text">Gestiona la estructura organizacional universitaria.</p>
                        <a class="btn app-secondary-button" asp-controller="Departments" asp-action="Index">Ir al módulo</a>
                    </div>
                </div>

                <div class="dashboard-card">
                    <div class="dashboard-card-body">
                        <h3 class="dashboard-card-title">Áreas de conocimiento</h3>
                        <p class="dashboard-card-text">Administra la clasificación académica por departamento.</p>
                        <a class="btn app-secondary-button" asp-controller="KnowledgeAreas" asp-action="Index">Ir al módulo</a>
                    </div>
                </div>

                <div class="dashboard-card">
                    <div class="dashboard-card-body">
                        <h3 class="dashboard-card-title">Titulaciones</h3>
                        <p class="dashboard-card-text">Consulta y administra las titulaciones registradas.</p>
                        <a class="btn app-secondary-button" asp-controller="DegreePrograms" asp-action="Index">Ir al módulo</a>
                    </div>
                </div>
            }
        </div>
    </section>
}