@model SIARU.Application.DTOs.TeachingAssignments.TeachingAssignmentDetailDto

@{
    ViewData["Title"] = "Eliminar impartición";
}

<div class="page-header">
    <h1 class="page-title">Eliminar impartición</h1>
    <p class="page-subtitle">Confirma si deseas eliminar esta impartición del sistema.</p>
</div>

<div class="form-card">
    <p class="mb-3">
        Estás a punto de eliminar la impartición:
        <strong>@Model.SubjectCode - @Model.SubjectName</strong>
    </p>

    <p class="text-muted">
        @Model.ProfessorName · @Model.AcademicYear
    </p>

    <form asp-action="DeleteConfirmed" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="subjectCode" value="@Model.SubjectCode" />
        <input type="hidden" name="professorId" value="@Model.ProfessorId" />
        <input type="hidden" name="academicYear" value="@Model.AcademicYear" />

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-danger">Eliminar</button>
            <a asp-action="Index" class="btn app-outline-button">Cancelar</a>
        </div>
    </form>
</div>