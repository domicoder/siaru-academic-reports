@model IEnumerable<SIARU.Application.DTOs.TeachingAssignments.TeachingAssignmentListDto>

@{
    ViewData["Title"] = "Imparticiones";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h1 class="page-title">Imparticiones</h1>
        <p class="page-subtitle">Gestiona qué profesor imparte cada asignatura por año académico.</p>
    </div>

    <a asp-action="Create" class="btn app-primary-button">Nueva impartición</a>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table app-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Asignatura</th>
                    <th>Profesor</th>
                    <th>Área</th>
                    <th>Año académico</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No hay imparticiones registradas.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SubjectCode - @item.SubjectName</td>
                            <td>@item.ProfessorName</td>
                            <td>@item.KnowledgeAreaName</td>
                            <td>@item.AcademicYear</td>
                            <td class="text-end">
                                <a asp-action="Details"
                                   asp-route-subjectCode="@item.SubjectCode"
                                   asp-route-professorId="@item.ProfessorId"
                                   asp-route-academicYear="@item.AcademicYear"
                                   class="btn btn-sm app-table-button">Ver</a>

                                <a asp-action="Edit"
                                   asp-route-subjectCode="@item.SubjectCode"
                                   asp-route-professorId="@item.ProfessorId"
                                   asp-route-academicYear="@item.AcademicYear"
                                   class="btn btn-sm app-table-button">Editar</a>

                                <a asp-action="Delete"
                                   asp-route-subjectCode="@item.SubjectCode"
                                   asp-route-professorId="@item.ProfessorId"
                                   asp-route-academicYear="@item.AcademicYear"
                                   class="btn btn-sm app-table-button-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>