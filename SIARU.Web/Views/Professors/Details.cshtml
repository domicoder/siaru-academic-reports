@model SIARU.Application.DTOs.Professors.ProfessorDetailDto

@{
    ViewData["Title"] = "Detalle de profesor";
}

<div class="page-header">
    <h1 class="page-title">Detalle de profesor</h1>
    <p class="page-subtitle">Consulta la información del profesor seleccionado.</p>
</div>

<div class="details-card">
    <dl class="row mb-0">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Despacho</dt>
        <dd class="col-sm-9">@Model.Office</dd>

        <dt class="col-sm-3">Área de conocimiento</dt>
        <dd class="col-sm-9">@Model.KnowledgeAreaName</dd>

        <dt class="col-sm-3">Departamento</dt>
        <dd class="col-sm-9">@Model.DepartmentName</dd>
    </dl>
</div>

<div class="mt-4 d-flex gap-2 flex-wrap">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn app-primary-button">Editar</a>
    <a asp-action="Index" class="btn app-outline-button">Volver</a>
</div>