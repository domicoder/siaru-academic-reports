@model SIARU.Application.DTOs.OfficeHours.UpdateOfficeHourDto

@{
    ViewData["Title"] = "Editar horario de consulta";
}

<div class="page-header">
    <h1 class="page-title">Editar horario de consulta</h1>
    <p class="page-subtitle">Actualiza el horario de consulta seleccionado.</p>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger app-alert mb-4"></div>

        <div class="mb-3">
            <label asp-for="ProfessorId" class="form-label"></label>
            <select asp-for="ProfessorId" asp-items="ViewBag.Professors" class="form-select app-form-control">
                <option value="">-- Selecciona un profesor --</option>
            </select>
            <span asp-validation-for="ProfessorId" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DayOfWeek" class="form-label"></label>
            <select asp-for="DayOfWeek" asp-items="ViewBag.WeekDays" class="form-select app-form-control">
                <option value="">-- Selecciona un día --</option>
            </select>
            <span asp-validation-for="DayOfWeek" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="StartTime" class="form-label"></label>
                <input asp-for="StartTime" type="time" class="form-control app-form-control" />
                <span asp-validation-for="StartTime" class="text-danger small"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="EndTime" class="form-label"></label>
                <input asp-for="EndTime" type="time" class="form-control app-form-control" />
                <span asp-validation-for="EndTime" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn app-primary-button">Guardar cambios</button>
            <a asp-action="Index" class="btn app-outline-button">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}