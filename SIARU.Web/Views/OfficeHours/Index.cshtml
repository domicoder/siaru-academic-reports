@model IEnumerable<SIARU.Application.DTOs.OfficeHours.OfficeHourListDto>

@{
    ViewData["Title"] = "Horarios de consulta";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h1 class="page-title">Horarios de consulta</h1>
        <p class="page-subtitle">Gestiona los horarios de consulta de los profesores.</p>
    </div>

    <a asp-action="Create" class="btn app-primary-button">Nuevo horario</a>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table app-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Profesor</th>
                    <th>Despacho</th>
                    <th>Área</th>
                    <th>Día</th>
                    <th>Inicio</th>
                    <th>Fin</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">No hay horarios de consulta registrados.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProfessorName</td>
                            <td>@item.ProfessorOffice</td>
                            <td>@item.KnowledgeAreaName</td>
                            <td>@item.DayOfWeek</td>
                            <td>@item.StartTime</td>
                            <td>@item.EndTime</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm app-table-button">Ver</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm app-table-button">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm app-table-button-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>