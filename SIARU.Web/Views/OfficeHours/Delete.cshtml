@model SIARU.Application.DTOs.OfficeHours.OfficeHourDetailDto

@{
    ViewData["Title"] = "Eliminar horario de consulta";
}

<div class="page-header">
    <h1 class="page-title">Eliminar horario de consulta</h1>
    <p class="page-subtitle">Confirma si deseas eliminar este horario del sistema.</p>
</div>

<div class="form-card">
    <p class="mb-3">
        Estás a punto de eliminar el horario de consulta de:
        <strong>@Model.ProfessorName</strong>
    </p>

    <p class="text-muted">
        @Model.DayOfWeek · @Model.StartTime - @Model.EndTime
    </p>

    <form asp-action="DeleteConfirmed" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-danger">Eliminar</button>
            <a asp-action="Index" class="btn app-outline-button">Cancelar</a>
        </div>
    </form>
</div>