@using SIARU.Application.Common
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIARU</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header>
        <nav class="navbar navbar-expand-lg app-navbar shadow-sm">
            <div class="container-fluid app-shell-container">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    <span class="app-brand-badge">SI</span>
                    <span class="app-brand-text">
                        <span class="app-brand-title">SIARU</span>
                        <span class="app-brand-subtitle">Sistema Académico Universitario</span>
                    </span>
                </a>

                <button class="navbar-toggler app-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Alternar navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 app-nav-list">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true &&
                            (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.StudentServicesStaff)))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle app-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Estructura académica
                                </a>
                                <ul class="dropdown-menu app-dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Departments" asp-action="Index">Departamentos</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="KnowledgeAreas" asp-action="Index">Áreas de conocimiento</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="DegreePrograms" asp-action="Index">Titulaciones</a>
                                    </li>
                                </ul>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated == true &&
                            (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.StudentServicesStaff) || User.IsInRole(RoleNames.ReadOnlyUser)))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle app-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Académico
                                </a>
                                <ul class="dropdown-menu app-dropdown-menu">
                                    <li>
                                        <a class="dropdown-item disabled" href="#">Asignaturas</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item disabled" href="#">Profesores</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item disabled" href="#">Horarios de consulta</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item disabled" href="#">Imparticiones</a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-controller="Reports" asp-action="Index">Informes</a>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(RoleNames.Administrator))
                        {
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" href="/Identity/Account/Manage">Administración</a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main">
        <div class="container-fluid app-shell-container">
            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success app-alert mt-4" role="alert">
                    @successMessage
                </div>
            }

            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="alert alert-danger app-alert mt-4" role="alert">
                    @errorMessage
                </div>
            }

            <section class="app-page-wrapper">
                @RenderBody()
            </section>
        </div>
    </main>

    <footer class="app-footer">
        <div class="container-fluid app-shell-container">
            <div class="app-footer-content">
                <span>SIARU</span>
                <span class="app-footer-separator">•</span>
                <span>Sistema Integrado de Información Académica y Reportes Universitarios</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>