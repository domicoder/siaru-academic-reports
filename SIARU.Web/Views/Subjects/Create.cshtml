@model SIARU.Application.DTOs.Subjects.CreateSubjectDto

@{
    ViewData["Title"] = "Crear asignatura";
}

<div class="page-header">
    <h1 class="page-title">Crear asignatura</h1>
    <p class="page-subtitle">Registra una nueva asignatura en el sistema.</p>
</div>

<div class="form-card">
    <form asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger app-alert mb-4"></div>

        <partial name="_SubjectForm" model="Model" />

        <div class="d-flex gap-2 flex-wrap mt-4">
            <button type="submit" class="btn app-primary-button">Guardar</button>
            <a asp-action="Index" class="btn app-outline-button">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}